# ============================================================================
# Environment Configuration for Persistent Memory
# ============================================================================
#
# This file shows configuration examples for BOTH deployment modes:
# - Local Mode (Default): Memory stored on your machine
# - Remote Mode (Enterprise): Memory on centralized server
#
# Choose ONE mode below and uncomment the relevant section.
# ============================================================================

# ----------------------------------------------------------------------------
# MODE 1: LOCAL MODE (Default - Zero Configuration)
# ----------------------------------------------------------------------------
# Best for: Individual developers, personal projects, single machines
# Setup: Works out of the box, no additional configuration needed
# Database: ~/.claude-mem/memory.db (on your machine)
# Cost: ~$15-30/month (your own Anthropic API key)
#
# Uncomment these lines for LOCAL MODE:
# ----------------------------------------------------------------------------

# Worker URL (local)
#WORKER_URL=http://localhost:37777

# Worker Port (local)
#WORKER_PORT=37777

# Database Path (local)
# Windows: %USERPROFILE%\.claude-mem\memory.db
# macOS/Linux: ~/.claude-mem/memory.db
#MEMORY_DB_PATH=${HOME}/.claude-mem/memory.db

# No API key needed for local authentication
#MEMORY_API_KEY=

# Your Anthropic API key (for AI compression)
# Get from: https://console.anthropic.com/
#ANTHROPIC_API_KEY=sk-ant-your-key-here


# ----------------------------------------------------------------------------
# MODE 2: REMOTE MODE (Enterprise - Team Deployment)
# ----------------------------------------------------------------------------
# Best for: Teams, multiple machines, shared context
# Setup: Requires one-time server deployment (20 minutes)
# Database: Centralized on remote server
# Cost: ~$150-300/month (team shared Anthropic API key on server)
#
# Uncomment these lines for REMOTE MODE:
# ----------------------------------------------------------------------------

# Worker URL (remote server)
WORKER_URL=http://10.10.100.20:37777
# OR with HTTPS (recommended for production):
#WORKER_URL=https://memory.company.com

# API Key for authentication (get from team lead)
# Generate on server: openssl rand -hex 32
MEMORY_API_KEY=5b79cc30dbd9734882b3726020203d3316d6cd789ebed956be0a04b7fea3dbe4

# Database path not used in remote mode (server manages database)
# MEMORY_DB_PATH not needed

# Anthropic API key not needed on client (server uses its own)
# ANTHROPIC_API_KEY not needed


# ----------------------------------------------------------------------------
# Additional Configuration (Both Modes)
# ----------------------------------------------------------------------------

# Log level (optional)
LOG_LEVEL=info

# Project name (auto-detected from directory, or set manually)
# PROJECT_NAME=template-ai-team


# ============================================================================
# How to Switch Modes
# ============================================================================
#
# Switch to Remote Mode:
# ----------------------
# Use the provided script:
#   bash deployment/client/configure-remote.sh http://your-server:37777 your-api-key
#
# Or manually:
#   1. Uncomment "REMOTE MODE" section above
#   2. Comment out "LOCAL MODE" section
#   3. Set WORKER_URL to your server URL
#   4. Set MEMORY_API_KEY to the key from your team lead
#   5. Restart Claude Code: exit && claude code
#
#
# Switch to Local Mode:
# ---------------------
# Use the provided script:
#   bash deployment/client/configure-local.sh
#
# Or manually:
#   1. Uncomment "LOCAL MODE" section above
#   2. Comment out "REMOTE MODE" section
#   3. Restart Claude Code: exit && claude code
#
#
# ============================================================================
# Remote Deployment Guide
# ============================================================================
#
# For complete remote server setup instructions, see:
#   - docs/guides/remote-memory-deployment.md (comprehensive guide)
#   - deployment/DEPLOYMENT-TOMORROW.md (step-by-step checklist)
#   - deployment/QUICK-START.md (15-minute quick setup)
#
# For security best practices, see:
#   - deployment/SECURITY.md (security hardening guide)
#
# For troubleshooting, see:
#   - deployment/TROUBLESHOOTING.md (common issues and solutions)
#
# ============================================================================


# ----------------------------------------------------------------------------
# MCP Integration (Optional)
# ----------------------------------------------------------------------------

# Jira Integration
JIRA_URL=https://jira.company.com
JIRA_TOKEN=your-jira-token-here

# Confluence Integration
CONFLUENCE_URL=https://confluence.company.com
CONFLUENCE_TOKEN=your-confluence-token-here

# VDS Partner Confluence (Optional)
VDS_CONFLUENCE_URL=http://10.254.136.35:8090
VDS_CONFLUENCE_PAT=your-vds-token-here

# MariaDB/MySQL Integration (Optional)
DB_HOST=localhost
DB_PORT=3306
DB_USER=claude_readonly
DB_PASSWORD=your-db-password-here
DB_NAME=your-database-name

# Figma Integration (Optional)
FIGMA_ACCESS_TOKEN=your-figma-token-here

# SonarQube Integration (Optional)
SONARQUBE_URL=https://sonarqube.company.com
SONARQUBE_TOKEN=your-sonarqube-token-here


# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# 1. NEVER commit this file with real credentials to Git
# 2. This file should be in .gitignore (already configured)
# 3. Use strong, randomly-generated API keys
# 4. Rotate API keys every 90 days
# 5. Store team API keys in password manager or company vault
# 6. For remote mode, use HTTPS in production (not HTTP)
# 7. Restrict firewall access to company network only
#
# ============================================================================
