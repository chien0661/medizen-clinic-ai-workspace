    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
