{
  "name": "vissoft-atlassian-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Jira and Confluence integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vissoft-atlassian-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "cross-env TRANSPORT=http node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "cross-env TRANSPORT=http tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "jira",
    "confluence",
    "atlassian"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "cross-env": "^10.1.0",
    "eventsource": "^4.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
