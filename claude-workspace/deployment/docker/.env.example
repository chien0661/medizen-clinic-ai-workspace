# Claude Memory Worker - Docker Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git!

# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Anthropic API Key (REQUIRED for memory compression)
# Get your API key from: https://console.anthropic.com/
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# API Key for client authentication (recommended for production)
# Generate with: openssl rand -hex 32
# Leave empty to disable authentication (not recommended)
API_KEY=

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Allowed CORS origins (comma-separated)
# Examples:
#   - Development: ALLOWED_ORIGINS=*
#   - Production: ALLOWED_ORIGINS=http://10.0.0.0/8,http://192.168.1.0/24
ALLOWED_ORIGINS=*

# ============================================
# ADVANCED CONFIGURATION (rarely needed)
# ============================================

# Worker port (default: 37777)
# Only change if port 37777 is already in use
# WORKER_PORT=37777

# Node environment
# NODE_ENV=production

# Database path (relative to /opt/claude-memory/)
# DB_PATH=data/memory.db

# Enable debug logging for SDK Agent
# SDK_DEBUG=false
